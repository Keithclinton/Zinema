# Example environment variables for Django/Postgres
DJANGO_SECRET_KEY=changeme
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*


# Railway Postgres connection variables
PGHOST=zinema.railway.internal
PGPORT=5432
PGDATABASE=ppv
PGUSER=ppvuser
PGPASSWORD=ppvpass

REDIS_URL=redis://redis:6379/0
DATABASE_PUBLIC_URL=postgresql://ppvuser:ppvpass@zinema.railway.internal:5432/ppv
